# Email Security Gateway - Environment Configuration
# IMPORTANT: Never commit this file to version control!

# =====================================================
# SECURITY SETTINGS
# =====================================================

# Environment mode: "development" or "production"
ENVIRONMENT=development

# API Authentication Key (required for production API access)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
API_KEY=change_this_to_a_secure_random_key

# Admin credentials (CHANGE THESE FOR PRODUCTION!)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123  # CHANGE THIS TO A STRONG PASSWORD

# CORS Allowed Origins (comma-separated list)
# For production, list only your actual domains
CORS_ALLOWED_ORIGINS=http://localhost:8501,http://localhost:8000

# Rate Limiting (requests per minute per IP)
RATE_LIMIT_ENABLED=false
RATE_LIMIT_PER_MINUTE=100

# =====================================================
# EXTERNAL API KEYS
# =====================================================

# VirusTotal v3 API Key
VIRUSTOTAL_API_KEY=e86b4cafe902b7830038a645e7d95d4e88ff84bfabd50097fb27cf6ef20048fd

# Google Safe Browsing API Key (get from https://console.cloud.google.com/)
GOOGLE_SAFE_BROWSING_API_KEY=your_google_api_key_here

# =====================================================
# TELEGRAM (DISABLED)
# =====================================================
# Telegram Bot Token (DISABLED - not used)
# TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# =====================================================
# TWILIO SMS (DISABLED)
# =====================================================
# Twilio Account SID (DISABLED - not used)
# TWILIO_ACCOUNT_SID=your_twilio_sid_here
# Twilio Auth Token (DISABLED - not used)
# TWILIO_AUTH_TOKEN=your_twilio_token_here

# =====================================================
# EMAIL SERVER SETTINGS
# =====================================================
SMTP_SERVER=localhost
SMTP_PORT=25
IMAP_SERVER=localhost
IMAP_PORT=143

# =====================================================
# DATABASE
# =====================================================
DATABASE_URL=sqlite:///email_security.db

# =====================================================
# MODEL PATHS
# =====================================================
MODEL_PATH=models_saved/bert_phishing_detector_v1
TINYBERT_MODEL_PATH=models_saved/tinybert_enron_spam

# =====================================================
# ALERT SETTINGS
# =====================================================
ADMIN_PHONE=+639123456789
ADMIN_EMAIL=admin@prototype.local

# =====================================================
# LOGGING
# =====================================================
LOG_LEVEL=INFO
LOG_FILE=logs/email_security.log